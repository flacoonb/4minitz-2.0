{
  "name": "nxtminutes",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "type-check": "tsc --noEmit",
    "security:check": "node scripts/security-check.mjs",
    "security:smoke": "node scripts/security-smoke-tests.mjs",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "clean": "rm -rf .next",
    "rebuild": "rm -rf .next && next build",
    "sample-data": "tsx scripts/sample-data.ts",
    "attachments:backfill-tags": "tsx scripts/backfill-attachment-tags.ts",
    "migrate-identifiers": "tsx scripts/migrate-identifiers-to-user-ids.ts",
    "create-demo-user": "tsx scripts/create-demo-user.ts",
    "create-user": "tsx scripts/create-user.ts",
    "setup": "./setup.sh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.8.0",
    "mongodb": "^7.1.1",
    "mongoose": "^8.23.0",
    "multer": "^2.1.1",
    "next": "^16.2.3",
    "next-intl": "^4.9.1",
    "nodemailer": "^8.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.4",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "dompurify": "^3.3.2",
    "fast-xml-parser": "^5.3.8",
    "flatted": "^3.4.2",
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "@parcel/watcher": {
      "picomatch": "^4.0.4"
    },
    "tinyglobby": {
      "picomatch": "^4.0.4"
    }
  }
