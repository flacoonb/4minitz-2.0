# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/nxtminutes

# JWT Secret (for authentication tokens)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-change-in-production-min-32-characters

# Encryption Secret (for encrypting sensitive data like SMTP passwords)
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=your-encryption-secret-change-in-production-min-32-characters

# App URL (used for cookie security and email links)
APP_URL=http://localhost:3000

# Trust X-Forwarded-* for client IP / RSVP redirects (set true only behind your own reverse proxy)
TRUST_PROXY_HEADERS=false

# Production: JWT via Authorization: Bearer is disabled unless you set this to true (API scripts / mobile)
# ALLOW_BEARER_AUTH=true

# Send Strict-Transport-Security when ENABLE_HSTS=true OR when NODE_ENV=production and APP_URL starts with https://
# ENABLE_HSTS=true
# DISABLE_HSTS=true

# CSP is set in proxy.ts (nonces + strict-dynamic for scripts). Emergency off: DISABLE_CSP=true
# Cloudflare Rocket Loader injects /cdn-cgi/... scripts without nonces → blocked by strict-dynamic.
# Prefer disabling Rocket Loader in Cloudflare. Last resort: CSP_DISABLE_STRICT_DYNAMIC=true (weaker CSP).
# Strict styles (no style unsafe-inline; breaks many components until refactored): CSP_STRICT_STYLES=true
# Extra origins (space/comma separated, no wildcards): CSP_EXTRA_IMG_SRC= CSP_EXTRA_CONNECT_SRC= CSP_EXTRA_SCRIPT_SRC=
# Cloudflare beacon (fixed hosts only): ALLOW_CLOUDFLARE_INSIGHTS=true
# CSP_UPGRADE_INSECURE_REQUESTS=true

# Email Configuration (SMTP)
# For development: Use MailHog (docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog)
# For production: Use Gmail, SendGrid, AWS SES, etc.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
FROM_EMAIL=noreply@nxtminutes.local

# App URL (used in emails and links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (VAPID)
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional, defaults to mailto:noreply@nxtminutes.local
# VAPID_SUBJECT=mailto:admin@example.invalid

# Cron Secret (for protected cron endpoints)
# Generate with: openssl rand -base64 32
CRON_SECRET=change-this-to-a-random-secret-min-32-chars

# Production Example:
# MONGODB_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@<CLUSTER_HOST>/<DB_NAME>?retryWrites=true&w=majority
# JWT_SECRET=<generated-with-openssl-rand-base64-32>
# ENCRYPTION_SECRET=<generated-with-openssl-rand-base64-32>
# APP_URL=https://yourdomain.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-gmail-app-password
# FROM_EMAIL=your-email@gmail.com
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# VAPID_PUBLIC_KEY=<generated-with-web-push-cli>
# VAPID_PRIVATE_KEY=<generated-with-web-push-cli>
# CRON_SECRET=<generated-with-openssl-rand-base64-32>
