# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/4minitz-next

# JWT Secret (for authentication tokens)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-change-in-production-min-32-characters

# Encryption Secret (for encrypting sensitive data like SMTP passwords)
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=your-encryption-secret-change-in-production-min-32-characters

# App URL (used for cookie security and email links)
APP_URL=http://localhost:3000

# Email Configuration (SMTP)
# For development: Use MailHog (docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog)
# For production: Use Gmail, SendGrid, AWS SES, etc.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
FROM_EMAIL=noreply@4minitz.local

# App URL (used in emails and links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# CSP mode for production response headers
# false (default): compatibility mode, allows required inline scripts
# true: strict mode, sets script-src to 'self' only
STRICT_CSP_MODE=false

# Web Push (VAPID)
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional, defaults to mailto:noreply@4minitz.local
# VAPID_SUBJECT=mailto:admin@example.com

# Cron Secret (for protected cron endpoints)
# Generate with: openssl rand -base64 32
CRON_SECRET=change-this-to-a-random-secret-min-32-chars

# Production Example:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/4minitz
# JWT_SECRET=<generated-with-openssl-rand-base64-32>
# ENCRYPTION_SECRET=<generated-with-openssl-rand-base64-32>
# APP_URL=https://yourdomain.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-gmail-app-password
# FROM_EMAIL=your-email@gmail.com
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# STRICT_CSP_MODE=true
# VAPID_PUBLIC_KEY=<generated-with-web-push-cli>
# VAPID_PRIVATE_KEY=<generated-with-web-push-cli>
# CRON_SECRET=<generated-with-openssl-rand-base64-32>
